# ── Security ──────────────────────────────────────────────
# Required for production: HTTP Basic Auth password
# If unset, UI runs without auth (local-only recommended).
APP_PASSWORD=changeme

# Default actor name when auth is disabled
APP_ACTOR_DEFAULT=local

# Required for production: encryption key for stored credentials (Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# APP_SECRET_KEY=change-this-to-a-long-random-string

# Rate limit failed login attempts
# APP_AUTH_MAX_ATTEMPTS=5
# APP_AUTH_WINDOW_SECONDS=300
# APP_AUTH_LOCKOUT_SECONDS=900
# APP_AUTH_TRUST_PROXY=false

# IP allowlist (comma-separated). If unset, all IPs allowed.
# APP_ALLOWED_IPS=127.0.0.1,192.168.1.0

# Enable HSTS header (set only when serving over HTTPS via reverse proxy)
# APP_ENABLE_HSTS=false

# Trading endpoint rate limits (per client per action)
# APP_RATE_LIMIT_MAX=10
# APP_RATE_LIMIT_WINDOW=60

# Optional: auto-abort stale sync runs after N minutes (prevents stuck RUNNING)
# SYNC_STALE_RUN_MINUTES=15

# SQLite database path
DATABASE_URL=sqlite:///./data/investor.db

# Optional: enable live network fetches for price refresh + certain connectors.
# NETWORK_ENABLED=1
# Optional: outbound allowlist (comma-separated) for network-enabled mode.
# Example for price refresh:
# ALLOWED_OUTBOUND_HOSTS=query1.finance.yahoo.com,finnhub.io
# Optional: Finnhub API key (used when selecting Finnhub as price provider in Holdings refresh).
# FINNHUB_API_KEY=your_key_here

# IBKR Configuration
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_ID=DUP579027
IBKR_PAPER_BACKEND=false
IBKR_LIVE_BACKEND=false
IBKR_EXECUTION_CLIENT_ID_OFFSET=20
IBKR_TIMEOUT=10
